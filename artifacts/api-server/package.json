    "drizzle-orm": "catalog:",
    "exceljs": "^4.4.0",
    "express": "^5",
    "express-session": "^1.19.0",
    "openai": "^6.32.0",
    "openid-client": "^6.8.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-linkedin-oauth2": "^2.0.0",
    "pino": "^9",
